.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
dist/
# Committed plugin dist bundles — see TODO-6-501 / PR #6.
# OpenClaw loads plugins/openclaw/*/dist/index.js at runtime; committed dist
# is the source of truth. Client-side enforcement: .githooks/pre-commit
# (opt-in via `git config core.hookspath .githooks`) runs scripts/verify-
# plugin-dist.sh on commit to catch src↔dist drift. Hook is escapable with
# --no-verify; interop reviewers verify parity independently per REVIEWING.md.
!openclaw-plugins/elephantbroker-context/dist/
!openclaw-plugins/elephantbroker-context/dist/**
!openclaw-plugins/elephantbroker-memory/dist/
!openclaw-plugins/elephantbroker-memory/dist/**
!plugins/openclaw/context/dist/
!plugins/openclaw/context/dist/**
!plugins/openclaw/memory/dist/
!plugins/openclaw/memory/dist/**
build/
.env
.ruff_cache/
node_modules/
.DS_Store
*.egg
.mypy_cache/
data/*.db
.claude/scheduled_tasks.lock

# LaTeX build artifacts
texput.log
*.missfont.log
missfont.log
*-eps-converted-to.pdf
local/pr-heartbeats/
