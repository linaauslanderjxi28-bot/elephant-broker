# Local deployment secrets for docker-compose.local.yml.
# Copy to /home/openclaw/docker/eb_infra/.env or export these variables before running compose.

EB_NEO4J_PASSWORD=change-me
EB_CLICKHOUSE_PASSWORD=
EB_MINIO_ROOT_USER=openclaw
EB_MINIO_ROOT_PASSWORD=change-me
EB_POSTGRES_PASSWORD=change-me

# Native ElephantBroker runtime runs on the host, not inside this compose network.
# Use localhost for host-published container services such as the local reranker.
EB_RERANKER_ENDPOINT=http://localhost:8004
