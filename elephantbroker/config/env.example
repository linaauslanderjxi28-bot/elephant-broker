# =============================================================================
# ElephantBroker — runtime environment file (template)
# =============================================================================
#
# This file is for SECRETS and per-host OVERRIDES only. ~90% of configuration
# lives in default.yaml — env vars exist as a deployment-specific override
# layer that takes precedence over YAML at runtime.
#
#   1. Copy this file to /etc/elephantbroker/env (or wherever your systemd unit
#      points its EnvironmentFile= directive).
#   2. Fill in the REQUIRED secrets at the top.
#   3. Uncomment and edit any optional override that differs from default.yaml.
#
# Conventions:
#   <UNCOMMENTED, BLANK>          → REQUIRED secret, fill before starting
#   # VAR=default_value           → optional override; uncomment + edit to use
#   # VAR=                        → optional, default is empty/null
#
# Resolution order (when loaded via `--config /etc/elephantbroker/default.yaml`):
#   env var (if set) > YAML value > schema default
#
# Every variable below overrides the corresponding YAML field at startup.
# See elephantbroker/schemas/config.py:ENV_OVERRIDE_BINDINGS for the full
# registry — adding a new EB_* env var to source code also requires adding
# it there. The inverse contract test in tests/unit/schemas walks the
# source tree and pins this rule.
#
# Identity (gateway_id, gateway_short_name, org_id, team_id, agent_authority_
# level) is intentionally NOT listed in this file. By deployment convention,
# identity lives in default.yaml only — it changes per-deployment, not per-host.
# (Override at runtime via env only if you have a deployment-specific reason;
# the env override mechanism still works for these vars, just not encouraged.)
# =============================================================================


# =============================================================================
# SECRETS — REQUIRED before starting
# =============================================================================
# These cannot live in YAML (they should never be committed to git). Fill them
# in here before bringing the runtime up.

# Primary LLM API key (extraction, classification, summarization, compaction).
# If empty, falls back to EB_EMBEDDING_API_KEY automatically.
EB_LLM_API_KEY=

# Embedding API key (Cognee uses this for vector indexing).
EB_EMBEDDING_API_KEY=

# Neo4j password. Override the dev default (`elephant_dev`) on every prod host.
EB_NEO4J_PASSWORD=

# HMAC secret for HITL approval callbacks. Generate with:
#   openssl rand -hex 32
# Must match the value set in /etc/elephantbroker/hitl.env on the same host.
EB_HITL_CALLBACK_SECRET=


# =============================================================================
# Infrastructure (Neo4j / Qdrant / Redis)
# =============================================================================
# Override these per-host if your DB instances are not on localhost or use
# non-default ports. The values below are the schema defaults.

# EB_NEO4J_URI=bolt://localhost:7687
# EB_NEO4J_USER=neo4j
# EB_QDRANT_URL=http://localhost:6333
# EB_REDIS_URL=redis://localhost:6379

# Cognee dataset namespace (gateway-scoped at runtime as `{gateway_id}__{this}`).
# DANGER: changing this on a running deployment orphans all existing Cognee data.
# EB_DEFAULT_DATASET=elephantbroker


# =============================================================================
# Observability — OTEL, log level, trace ledger, ClickHouse
# =============================================================================

# Set to ship spans to a Jaeger / OTEL Collector endpoint.
# When unset, all @traced spans become no-ops (zero overhead, zero visibility).
# EB_OTEL_ENDPOINT=http://localhost:4317

# Log verbosity. Custom 'verbose' level shows per-item assembly decisions
# without DEBUG payload dumps. Uvicorn maps 'verbose' → 'info' internally.
# EB_LOG_LEVEL=INFO

# How long Prometheus counter samples stay in the in-memory store.
# EB_METRICS_TTL_SECONDS=3600

# In-memory TraceLedger ring buffer (per-runtime, lost on restart).
# EB_TRACE_MEMORY_MAX_EVENTS=10000
# EB_TRACE_OTEL_LOGS_ENABLED=false

# Master kill switch for the trace ledger. Disable only for benchmarks —
# losing trace events removes all forensic visibility.
# EB_ENABLE_TRACE_LEDGER=true

# ClickHouse — durable cross-session trace analytics. When enabled, trace
# events flow OTEL Collector → ClickHouse for querying via /trace API.
# Required for Phase 9 consolidation Stage 7 (procedure pattern detection).
# EB_CLICKHOUSE_ENABLED=false
# EB_CLICKHOUSE_HOST=localhost
# EB_CLICKHOUSE_PORT=8123
# EB_CLICKHOUSE_DATABASE=otel
# EB_CLICKHOUSE_USER=default
# EB_CLICKHOUSE_PASSWORD=                # REQUIRED on managed clusters (Aiven, ClickHouse Cloud, Altinity)
# EB_CLICKHOUSE_LOGS_TABLE=otel_logs     # override if your OTEL Collector writes to a different table


# =============================================================================
# LLM — primary model for fact extraction, classification, summarization
# =============================================================================

# IMPORTANT: keep the openai/ prefix. Cognee requires it for routing through
# its OpenAI-compatible client and strips it internally before sending to
# LiteLLM (which sees "gemini/gemini-2.5-pro"). Without the prefix, Cognee
# hangs at startup on the LLM connection test.
# EB_LLM_MODEL=openai/gemini/gemini-2.5-pro

# --- LLM endpoint ---
# EB_LLM_ENDPOINT controls where Cognee sends chat/completions requests.
# The default http://localhost:8811/v1 is CORRECT ONLY when your LiteLLM
# proxy runs on the same host as ElephantBroker. If LiteLLM runs on a
# different VM (a common production layout), you MUST set this to the
# remote URL — otherwise the runtime silently falls back to localhost
# and all LLM calls fail with httpx.ConnectError at first use.
#
# Examples:
#   same-host LiteLLM:  EB_LLM_ENDPOINT=http://localhost:8811/v1
#   remote LiteLLM:     EB_LLM_ENDPOINT=http://10.0.1.42:8811/v1
#   OpenAI passthrough: EB_LLM_ENDPOINT=https://api.openai.com/v1
EB_LLM_ENDPOINT=http://localhost:8811/v1
# EB_LLM_MAX_TOKENS=8192
# EB_LLM_TEMPERATURE=0.1
# EB_LLM_EXTRACTION_MAX_INPUT_TOKENS=4000
# EB_LLM_EXTRACTION_MAX_OUTPUT_TOKENS=16384
# EB_LLM_EXTRACTION_MAX_FACTS=10
# EB_LLM_SUMMARIZATION_MAX_OUTPUT_TOKENS=200
# EB_LLM_SUMMARIZATION_MIN_CHARS=500


# =============================================================================
# Embedding — model + dimensions MUST match your LiteLLM proxy
# =============================================================================
# Cognee tokenizes via tiktoken which only knows OpenAI model names. To use a
# non-OpenAI embedding model (gemini, voyage, cohere, etc.) you must verify
# your LiteLLM proxy actually serves that model AND the dimensions match the
# model's actual output (otherwise Qdrant collections become orphaned and
# all retrieval breaks). When in doubt, stay on text-embedding-3-large.
#
# Before pinning EB_EMBEDDING_DIMENSIONS for a non-default model, probe
# the real output dimension with a curl against /embeddings — see
# docs/DEPLOYMENT.md § Probe-then-configure embedding dimensions. Aliases
# and LiteLLM's `dimensions` truncation can make the canonical dim wrong.

# EB_EMBEDDING_MODEL=gemini/text-embedding-004
# EB_EMBEDDING_DIMENSIONS=768
# EB_EMBEDDING_PROVIDER=openai          # API client style; works for any LiteLLM backend

# --- Embedding endpoint ---
# EB_EMBEDDING_ENDPOINT controls where Cognee sends /embeddings requests.
# The default http://localhost:8811/v1 is CORRECT ONLY when your LiteLLM
# proxy runs on the same host as ElephantBroker. If LiteLLM runs on a
# different VM (a common production layout), you MUST set this to the
# remote URL — otherwise the runtime silently falls back to localhost
# and all embedding calls fail with httpx.ConnectError at first use.
#
# Examples:
#   same-host LiteLLM:  EB_EMBEDDING_ENDPOINT=http://localhost:8811/v1
#   remote LiteLLM:     EB_EMBEDDING_ENDPOINT=http://10.0.1.42:8811/v1
#   OpenAI passthrough: EB_EMBEDDING_ENDPOINT=https://api.openai.com/v1
EB_EMBEDDING_ENDPOINT=http://localhost:8811/v1
# EB_EMBEDDING_CACHE_ENABLED=true
# EB_EMBEDDING_CACHE_TTL=3600


# =============================================================================
# Compaction LLM — separate (cheaper) model for compaction summaries
# =============================================================================
# Defaults to gemini-2.5-flash-lite. The unsuffixed "gemini/gemini-2.5-flash"
# alias on the staging LiteLLM proxy resolves to a deleted Gemini preview and
# returns HTTP 404 — flash-lite is the working flash-class replacement.
# Override if your LiteLLM proxy doesn't expose that model. Both api_key AND
# endpoint fall back to EB_LLM_API_KEY / EB_LLM_ENDPOINT automatically when
# empty (F7) — only set the lines below if compaction targets a *different*
# LiteLLM proxy than the primary LLM.

# EB_COMPACTION_LLM_MODEL=gemini/gemini-2.5-flash-lite
# EB_COMPACTION_LLM_ENDPOINT=             # leave empty to inherit EB_LLM_ENDPOINT
# EB_COMPACTION_LLM_API_KEY=              # leave empty to inherit EB_LLM_API_KEY


# =============================================================================
# Reranker — Qwen3-Reranker-4B cross-encoder
# =============================================================================
# Requires a separate inference server (vLLM, TEI, etc.) hosting the model.
# Reranker is ENABLED by default — GPU-heavy. Set EB_RERANKER_ENABLED=false
# on CPU-only hosts or when you don't have a Qwen3-Reranker server up;
# retrieval falls back to scoring-only ranking with no cross-encoder step.

# EB_RERANKER_ENABLED=true
# EB_RERANKER_ENDPOINT=http://localhost:1235
# EB_RERANKER_API_KEY=
# EB_RERANKER_MODEL=Qwen/Qwen3-Reranker-4B


# =============================================================================
# HITL (human-in-the-loop approval middleware)
# =============================================================================
# Approval middleware for high-risk actions. When enabled, the runtime POSTs
# approval requests to the hitl-middleware service before high-risk actions
# proceed. Requires hitl-middleware running (see hitl-middleware/ package and
# deploy/systemd/elephantbroker-hitl.service). The callback HMAC secret lives
# in the "Required secrets" section at the top of this file.

# EB_HITL_ENABLED=false


# =============================================================================
# Dashboard auth — SuperTokens + API keys (Phase 11)
# =============================================================================
# Disabled by default. When off, AuthMiddleware only stamps request identity and
# never blocks — backward compatible with pre-Phase-11 deploys. Turn on to
# enforce session / API-key auth on /admin and /dashboard, mount the SuperTokens
# /auth/* routes, and enable credentialed CORS for the dashboard origin.
#
# Requires SuperTokens Core running (see infrastructure/docker-compose.yml —
# `docker compose --profile auth up supertokens`) and the supertokens-python
# package installed (it is a pinned dependency but lazy-imported).

# EB_DASHBOARD_AUTH_ENABLED=false
# EB_SUPERTOKENS_CORE_URI=http://localhost:3567
# EB_DASHBOARD_API_DOMAIN=http://localhost:8420
# EB_DASHBOARD_WEBSITE_DOMAIN=http://localhost:5173   # dashboard origin used for CORS
# EB_DASHBOARD_COOKIE_SECURE=false                    # set true behind HTTPS in production
# EB_DASHBOARD_COOKIE_SAME_SITE=lax                   # lax | strict | none
# EB_DASHBOARD_STATIC_DIR=                            # built dashboard bundle served at /ui (empty = off)
# EB_DASHBOARD_BOOTSTRAP_COMPLETE=false               # set true after the first admin is created

# SQLite store paths (Phase 11 dashboard). Point these at your data directory.
# EB_API_KEYS_DB_PATH=data/api_keys.db
# EB_CUSTOM_GUARD_RULES_DB_PATH=data/custom_guard_rules.db
# EB_DASHBOARD_DB_PATH=data/dashboard.db

# SuperTokens Core → PostgreSQL (docker-compose 'auth-prod' profile). Consumed
# by infrastructure/docker-compose.yml, NOT by the runtime. Leave the URI empty
# for dev (SuperTokens Core runs in-memory).
# SUPERTOKENS_POSTGRES_URI=postgresql://supertokens:supertokens_dev@localhost:15432/supertokens
# SUPERTOKENS_POSTGRES_PASSWORD=supertokens_dev


# =============================================================================
# Working set scoring + ingest pipeline tuning
# =============================================================================

# EB_SCORING_SNAPSHOT_TTL=300            # must exceed expected single-turn duration
# EB_SESSION_GOALS_TTL=86400             # 24h
# EB_INGEST_BATCH_SIZE=6                 # messages buffered before triggering ingest
# EB_INGEST_BATCH_TIMEOUT=60.0           # max wait before forcing ingest
# EB_INGEST_BUFFER_TTL=300               # Redis buffer TTL (must exceed batch timeout)
# EB_EXTRACTION_CONTEXT_FACTS=20         # recent facts injected into extraction prompt
# EB_EXTRACTION_CONTEXT_TTL=3600


# =============================================================================
# Successful-use feedback (Phase 9, off by default)
# =============================================================================
# When enabled, runs an LLM batch evaluation per turn to determine which
# injected facts actually contributed to agent actions. Used by the
# consolidation pipeline to strengthen useful facts and decay useless ones.
# Cost: ~1 LLM call per turn batch. Enable for long-running deployments.

# EB_SUCCESSFUL_USE_ENABLED=false
# EB_SUCCESSFUL_USE_ENDPOINT=http://localhost:8811/v1
# EB_SUCCESSFUL_USE_API_KEY=             # falls back to EB_LLM_API_KEY
# EB_SUCCESSFUL_USE_MODEL=gemini/gemini-2.5-flash-lite
# EB_SUCCESSFUL_USE_BATCH_SIZE=5


# =============================================================================
# Top-level toggles & global limits
# =============================================================================

# EB_DEFAULT_PROFILE=coding              # coding | research | managerial | worker | personal_assistant
# EB_GUARDS_ENABLED=true                 # master switch for the 6-layer guard pipeline (overrides guards.enabled)
# EB_MAX_CONCURRENT_SESSIONS=100         # session rejection threshold
# EB_CONSOLIDATION_MIN_RETENTION_SECONDS=172800   # 48h — min age before consolidation can decay a fact


# =============================================================================
# Consolidation scheduling
# =============================================================================
# F4 (TODO-3-009): these two used to be read directly from os.environ inside
# a lazy `consolidation` property — invisible to ENV_OVERRIDE_BINDINGS and the
# inverse contract test. They are now first-class registry entries that
# override the matching `consolidation:` block in default.yaml.

# EB_DEV_CONSOLIDATION_AUTO_TRIGGER=0    # 0 = off; or "5m" / "1h" / "1d" for dev auto-trigger
# EB_CONSOLIDATION_BATCH_SIZE=500


# =============================================================================
# Cognee internals (do not usually touch)
# =============================================================================
# Already set by elephantbroker/__init__.py at import time — listed for awareness.
# COGNEE_DISABLE_TELEMETRY=true


# =============================================================================
# Production minimum — copy-paste starting point
# =============================================================================
# A typical production env file ends up with just these 7-9 lines. Everything
# else stays in default.yaml. Uncomment the block below and fill in the values.
#
# # --- secrets ---
# EB_LLM_API_KEY=sk-your-litellm-key
# EB_EMBEDDING_API_KEY=sk-your-litellm-key      # often same as LLM key
# EB_NEO4J_PASSWORD=your-strong-neo4j-password
# EB_HITL_CALLBACK_SECRET=                       # openssl rand -hex 32
#
# # --- per-host infra (only if differ from default.yaml) ---
# EB_NEO4J_URI=bolt://db-vm:7687
# EB_QDRANT_URL=http://db-vm:6333
# EB_REDIS_URL=redis://db-vm:6379
#
# # --- LLM/embedding endpoints (REQUIRED if LiteLLM is remote) ---
# EB_LLM_ENDPOINT=http://<litellm-host>:8811/v1        # REQUIRED if LiteLLM is remote — see §LLM endpoint above
# EB_EMBEDDING_ENDPOINT=http://<litellm-host>:8811/v1  # REQUIRED if LiteLLM is remote — keep in sync with EB_LLM_ENDPOINT
#
# # --- observability (optional) ---
# EB_OTEL_ENDPOINT=http://otel-collector:4317
