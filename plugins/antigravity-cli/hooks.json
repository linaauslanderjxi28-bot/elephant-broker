{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/session-start.py",
            "timeout": 15000,
            "statusMessage": "Initializing ElephantBroker memory..."
          }
        ]
      }
    ],
    "PreInvocation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/agy-pre-invocation.py",
            "timeout": 5000,
            "statusMessage": "Searching ElephantBroker memory..."
          }
        ]
      }
    ],
    "PostInvocation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/agy-post-invocation.py",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/sync-session-to-graph.py --session-end",
            "timeout": 30000,
            "statusMessage": "Closing ElephantBroker memory session..."
          }
        ]
      }
    ]
  }
}
