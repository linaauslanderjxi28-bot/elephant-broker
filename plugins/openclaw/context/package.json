{
  "name": "elephantbroker-context",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/index.js --external:@opentelemetry/* --external:openclaw",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/sdk-trace-base": "1.30.1"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "esbuild": "0.25.0",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
