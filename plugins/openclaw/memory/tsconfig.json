{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "types": ["vitest/globals"]
  },
  "include": ["index.ts", "src/**/*.ts", "tests/**/*.ts", "../shared/envelope.ts"]
}
