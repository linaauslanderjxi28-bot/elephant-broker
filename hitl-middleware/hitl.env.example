# =============================================================================
# ElephantBroker HITL Middleware — environment file (template)
# =============================================================================
#
# The HITL middleware is a SEPARATE service from the main runtime. It runs as
# its own systemd unit (elephantbroker-hitl.service) on port 8421 and acts as
# the human-in-the-loop approval queue: the runtime POSTs approval requests
# here, the middleware delivers them via configured webhooks (Slack, email,
# etc.), waits for human response, and POSTs the result back to the runtime.
#
#   1. Copy this file to /etc/elephantbroker/hitl.env (same directory as the
#      main runtime env file — both env files are owned by the elephantbroker
#      service user with mode 640).
#   2. Fill in EB_HITL_CALLBACK_SECRET and EB_HITL_RUNTIME_AUTH_TOKEN with the
#      SAME values as the runtime's env file. The HMAC and runtime token must
#      match for callback verification and runtime PATCH authorization to succeed.
#   3. Adjust HITL_HOST / HITL_PORT only if you need to bind to a non-default
#      address (e.g. for multi-instance deployments).
#
# Source schema: hitl_middleware/config.py:HitlMiddlewareConfig
# Loaded by:     hitl_middleware.__main__ via HitlMiddlewareConfig.from_env()
# =============================================================================


# =============================================================================
# REQUIRED — must match runtime
# =============================================================================
# HMAC-SHA256 secret used to verify callback signatures from the HITL service
# back to the runtime. MUST be identical to EB_HITL_CALLBACK_SECRET in the
# runtime's /etc/elephantbroker/env file. Generate once with:
#   openssl rand -hex 32
# Then set the same value in BOTH files. A mismatch causes callbacks to fail
# silently with a 401 from the runtime, leaving approvals in a pending state.
EB_HITL_CALLBACK_SECRET=

# Dedicated token sent by HITL middleware to the runtime when PATCHing
# /guards/approvals/{request_id}. MUST match EB_HITL_RUNTIME_AUTH_TOKEN in the
# runtime's /etc/elephantbroker/env file.
EB_HITL_RUNTIME_AUTH_TOKEN=


# =============================================================================
# Bind address & port
# =============================================================================
# Defaults are 0.0.0.0:8421 — bound to all interfaces so the runtime can reach
# it from the same host (and so OpenClaw on a separate VM can reach it too if
# you expose port 8421 in your firewall).

# HITL_HOST=0.0.0.0
# HITL_PORT=8421


# =============================================================================
# Log level
# =============================================================================
# IMPORTANT: HITL middleware uses uvicorn's standard log levels. Unlike the
# main runtime, it does NOT support the custom 'verbose' level — using it will
# fail at startup. Valid values: debug | info | warning | error | critical

# HITL_LOG_LEVEL=info


# =============================================================================
# Runtime callback URL
# =============================================================================
# Where the HITL middleware POSTs approval results back to. Must point to the
# main runtime's API (typically same host as HITL middleware, port 8420).
# Override if the runtime is on a different host or non-default port.

# EB_RUNTIME_URL=http://localhost:8420


# =============================================================================
# Notes on what's NOT here
# =============================================================================
#
# Webhook configuration (notification_endpoints, approval_endpoints, retry
# settings) is NOT loaded from environment variables — it must be set via a
# config file or direct config object construction in deployment-specific code.
# See hitl_middleware/config.py:WebhookConfig for the schema.
#
# Identity (gateway_id, agent_id) is irrelevant for the HITL middleware — it
# is a stateless relay between the runtime and human approvers. The runtime
# is the one that stamps gateway_id on every request it forwards here.
