# ElephantBroker dashboard environment variables.
# Copy to `.env.development` (local) and `.env.production` (build) as needed.
#
# In development the dashboard runs on http://localhost:5173 and talks to the
# EB runtime cross-origin. In production the runtime serves the built bundle at
# `/ui/*`, so the runtime URL is empty (same-origin) — see `.env.production`.

# Base URL of the EB runtime (FastAPI, default port 8420).
# Leave EMPTY in production for same-origin requests.
VITE_EB_RUNTIME_URL=http://localhost:8420

# --- SuperTokens (frontend SDK) ---
# apiDomain must point at the EB runtime that hosts the SuperTokens `/auth/*`
# routes. websiteDomain is where this dashboard is served.
VITE_ST_API_DOMAIN=http://localhost:8420
VITE_ST_WEBSITE_DOMAIN=http://localhost:5173
VITE_ST_API_BASE_PATH=/auth
VITE_ST_APP_NAME=ElephantBroker Dashboard
